{# 
 # Template de la page d'accueil
 #
 # Affiche :
 # - Une image de fond représentant une agora grecque
 # - Un message de bienvenue personnalisé avec le nom de l'utilisateur
 #
 # Hérite du template de base qui fournit la structure commune
 #}
{% extends "base.html.twig" %}

{# Bloc principal du contenu #}
{% block central %}
    <div class="container">
        <div id="blocImage">
            {# Image principale de l'agora #}
            <img src="{{ asset('assets/img/greece-3348294_1280.jpg') }}" 
                 alt="Agora grecque antique" 
                 class="responsive">

            {# Message de bienvenue personnalisé avec effet typing sur le nom #}
            <div id="blocImageTexte">
                Bonjour <span id="typing-name" class="text-primary">{% if app.user %}{{ app.user.prenomMembre }} {{ app.user.nomMembre }}{% elseif app.session.get('prenomUtilisateur') %}{{ app.session.get('prenomUtilisateur') }} {{ app.session.get('nomUtilisateur') }}{% else %}Utilisateur{% endif %}</span><span class="typing-cursor">|</span>
            </div>
            </div>
        </div>

    {# Effet typing sur le nom de l'utilisateur #}
    <script>
    (function() {
        const el = document.getElementById('typing-name');
        if (!el) return;
        const text = el.textContent.trim();
        if (!text) return;
        el.textContent = '';
        let i = 0;
        const speed = 80;
        const cursor = document.querySelector('.typing-cursor');
        function type() {
            if (i < text.length) {
                el.textContent += text.charAt(i);
                i++;
                setTimeout(type, speed);
            } else if (cursor) {
                cursor.style.opacity = '0';
            }
        }
        setTimeout(type, 400);
    })();
    </script>
    <style>
        .typing-cursor {
            animation: blink 0.7s step-end infinite;
            margin-left: 2px;
            color: pink;
            font-size: 50px;
        }
        @keyframes blink {
            50% { opacity: 0; }
        }
    </style>
    {% endblock %}