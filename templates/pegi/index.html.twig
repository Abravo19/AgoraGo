{% extends 'base.html.twig' %}

{% block body %}
    <!-- page start--><div class="col-sm-8">
<section class="panel">
<div class="chat-room-head">
<h3><i class="fa fa-angle-right"></i> Gérer les classifications PEGI</h3>
</div>
<div class="panel-body">

    <table class="table" table-striped table-advance table-hover"> 
        <thead>
            <tr>
                <th>class="tableau-entete"</th>
                <th><i class="fa fa-bullhorn"></i> Identif</th>
                <th><i class="fa fa-bookmark"></i> Âge PEGI</th>
            </tr>
        </thead>
        <tbody>
        {% for pegi in pegis %}
            <tr>
                <td>{{ pegi.id }}</td>
                <td>{{ pegi.agePegi }}</td>
                <td>
                    <a href="{{path('app_pegi_show',{'id': pegi.id})}}"><button
class="btn btn-primary btn-xs"><i class="fa fa-tasks"></i></button></a>
<a href="{{path('app_pegi_edit',{'id': pegi.id})}}"><button
class="btn btn-primary btn-xs"><i class="fa fa-pencil"></i></button></a>
</td>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="3">aucune classification PEGI enregistrée en base de données</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_pegi_new') }}"><button class="btn btn-primary btn-
xs"><i class="fa fa-plus"></i></button></a>
</div><!-- fin div panel-body-->
</section><!-- fin section pegis-->
</div><!--fin div col-sm-8-->
{% endblock %}
