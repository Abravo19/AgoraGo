{% extends '@EasyAdmin/page/content.html.twig' %}

{% block page_title %}Dashboard Agora{% endblock %}

{% block main %}
<div class="row">
    <!-- Statistiques principales -->
    <div class="col-12 col-md-6 col-lg-3 mb-4">
        <div class="card text-white bg-primary h-100">
            <div class="card-body d-flex flex-column justify-content-between">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h2 class="mb-0">{{ stats.jeux }}</h2>
                        <p class="mb-0">Jeux Vidéo</p>
                    </div>
                    <i class="fas fa-gamepad fa-3x opacity-50"></i>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0">
                <a href="{{ path('admin', {crudAction: 'index', crudControllerFqcn: 'App\\\\Controller\\\\Admin\\\\JeuVideoCrudController'}) }}" class="text-white text-decoration-none">
                    Voir tous <i class="fas fa-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6 col-lg-3 mb-4">
        <div class="card text-white bg-success h-100">
            <div class="card-body d-flex flex-column justify-content-between">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h2 class="mb-0">{{ stats.tournois }}</h2>
                        <p class="mb-0">Tournois</p>
                    </div>
                    <i class="fas fa-trophy fa-3x opacity-50"></i>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0">
                <a href="{{ path('admin', {crudAction: 'index', crudControllerFqcn: 'App\\\\Controller\\\\Admin\\\\TournoiCrudController'}) }}" class="text-white text-decoration-none">
                    Voir tous <i class="fas fa-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6 col-lg-3 mb-4">
        <div class="card text-white bg-warning h-100">
            <div class="card-body d-flex flex-column justify-content-between">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h2 class="mb-0">{{ stats.membres }}</h2>
                        <p class="mb-0">Membres</p>
                    </div>
                    <i class="fas fa-users fa-3x opacity-50"></i>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0">
                <a href="{{ path('admin', {crudAction: 'index', crudControllerFqcn: 'App\\\\Controller\\\\Admin\\\\MembreCrudController'}) }}" class="text-white text-decoration-none">
                    Voir tous <i class="fas fa-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6 col-lg-3 mb-4">
        <div class="card text-white bg-danger h-100">
            <div class="card-body d-flex flex-column justify-content-between">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h2 class="mb-0">{{ stats.participants }}</h2>
                        <p class="mb-0">Participants</p>
                    </div>
                    <i class="fas fa-user-check fa-3x opacity-50"></i>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0">
                <a href="{{ path('admin', {crudAction: 'index', crudControllerFqcn: 'App\\\\Controller\\\\Admin\\\\ParticipantCrudController'}) }}" class="text-white text-decoration-none">
                    Voir tous <i class="fas fa-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Section informations -->
<div class="row mt-4">
    <div class="col-12 col-lg-6 mb-4">
        <div class="card h-100">
            <div class="card-header bg-light">
                <h5 class="mb-0"><i class="fas fa-info-circle me-2"></i>Bienvenue sur Agora</h5>
            </div>
            <div class="card-body">
                <p>Bienvenue sur le panneau d'administration d'<strong>Agora</strong>.</p>
                <p>Depuis cette interface, vous pouvez gérer :</p>
                <ul>
                    <li><i class="fas fa-gamepad text-primary me-2"></i>Les jeux vidéo</li>
                    <li><i class="fas fa-trophy text-success me-2"></i>Les tournois</li>
                    <li><i class="fas fa-users text-warning me-2"></i>Les membres</li>
                    <li><i class="fas fa-list text-info me-2"></i>Les genres, plateformes, marques...</li>
                </ul>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-6 mb-4">
        <div class="card h-100">
            <div class="card-header bg-light">
                <h5 class="mb-0"><i class="fas fa-chart-bar me-2"></i>Autres statistiques</h5>
            </div>
            <div class="card-body">
                <ul class="list-group list-group-flush">
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span><i class="fas fa-tags text-secondary me-2"></i>Genres</span>
                        <span class="badge bg-secondary rounded-pill">{{ stats.genres }}</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span><i class="fas fa-desktop text-secondary me-2"></i>Plateformes</span>
                        <span class="badge bg-secondary rounded-pill">{{ stats.plateformes }}</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span><i class="fas fa-building text-secondary me-2"></i>Marques</span>
                        <span class="badge bg-secondary rounded-pill">{{ stats.marques }}</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span><i class="fas fa-folder text-secondary me-2"></i>Catégories Tournois</span>
                        <span class="badge bg-secondary rounded-pill">{{ stats.categories }}</span>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>
{% endblock %}
