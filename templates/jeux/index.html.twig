{% extends 'base.html.twig' %}

{% block body %}
    <!-- page start--><div class="col-sm-8">
<section class="panel">
<div class="chat-room-head">
<h3><i class="fa fa-angle-right"></i> Gérer les jeux</h3>
</div>
<div class="panel-body">

    <table class="table" table-striped table-advance table-hover"> 
        <thead>
            <tr>
                <th>class="tableau-entete"</th>
                <th><i class="fa fa-bullhorn"></i> Titre</th>
                <th><i class="fa fa-bookmark"></i> Description</th>
                <th><i class="fa fa-bookmark"></i> Genre</th>
                <th><i class="fa fa-bookmark"></i> Plateforme</th>
                <th><i class="fa fa-bookmark"></i> PEGI</th>
                <th><i class="fa fa-bookmark"></i> Marque</th>
            </tr>
        </thead>
        <tbody>
        {% for jeu in jeux %}
            <tr>
                <td>{{ jeu.id }}</td>
                <td>{{ jeu.titre }}</td>
                <td>{{ jeu.description|slice(0, 50) }}{{ jeu.description|length > 50 ? '...' : '' }}</td>
                <td>{{ jeu.genre ? jeu.genre.libGenre : '-' }}</td>
                <td>{{ jeu.plateforme ? jeu.plateforme.libPlateforme : '-' }}</td>
                <td>{{ jeu.pegi ? jeu.pegi.agePegi : '-' }}</td>
                <td>{{ jeu.marque ? jeu.marque.nomMarque : '-' }}</td>
                <td>
                    <a href="{{path('app_jeux_show',{'id': jeu.id})}}"><button
class="btn btn-primary btn-xs"><i class="fa fa-tasks"></i></button></a>
<a href="{{path('app_jeux_edit',{'id': jeu.id})}}"><button
class="btn btn-primary btn-xs"><i class="fa fa-pencil"></i></button></a>
</td>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="8">aucun jeu enregistré en base de données</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_jeux_new') }}"><button class="btn btn-primary btn-
xs"><i class="fa fa-plus"></i></button></a>
</div><!-- fin div panel-body-->
</section><!-- fin section jeux-->
</div><!--fin div col-sm-8-->
{% endblock %}
