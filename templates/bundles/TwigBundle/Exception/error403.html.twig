{% extends 'base.html.twig' %}

{% block body %}
<div class="row">
    <div class="col-12">
        <section class="panel">
            <div class="chat-room-head">
                <h3><i class="fa fa-lock"></i> Accès refusé</h3>
            </div>
            <div class="panel-body text-center" style="padding: 60px 40px;">
                <div class="error-403-icon" style="font-size: 80px; color: var(--important, #ff6c60); margin-bottom: 20px;">
                    <i class="fa fa-ban"></i>
                </div>
                <h2 style="color: var(--text-main); margin-bottom: 15px;">Vous n'avez pas les droits nécessaires</h2>
                <p class="text-muted" style="font-size: 1.1em; margin-bottom: 30px;">
                    Cette page est réservée aux administrateurs. Votre compte ne dispose pas des privilèges requis pour y accéder.
                </p>
                <div>
                    <a href="{{ path('accueil') }}" class="btn btn-primary">
                        <i class="fa fa-home"></i> Retour à l'accueil
                    </a>
                </div>
            </div>
        </section>
    </div>
</div>
{% endblock %}
