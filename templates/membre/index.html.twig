{% extends 'base.html.twig' %}

{% block body %}
<!-- page start-->
<div class="row">
<div class="col-12">
    <section class="panel">
        <div class="chat-room-head">
            <h3><i class="fa fa-angle-right"></i> Gérer les membres</h3>
        </div>
        <div class="panel-body">
    <div class="table-responsive">
    <table class="table table-striped table-advance table-hover">
        <thead>
            <tr class="tableau-entete">
                <th><i class="fa fa-bullhorn"></i> Id</th>
                <th><i class="fa fa-bookmark"></i> Identifiant</th>
                <th><i class="fa fa-user"></i> Nom</th>
                <th><i class="fa fa-envelope"></i> Email</th>
                <th><i class="fa fa-key"></i> Mot de passe</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        {% for membre in membres %}
            <tr{% if app.user and membre.id == app.user.id %} class="table-current-user"{% endif %}>
                <td>{{ membre.id }}</td>
                <td>
                    {{ membre.username }}
                    {% if app.user and membre.id == app.user.id %}<span class="badge badge-current-user"></span>{% endif %}
                </td>
                <td>{{ membre.prenomMembre }} {{ membre.nomMembre }}</td>
                <td>{{ membre.mailMembre }}</td>
                <td>{{ membre.password }}</td>
                <td>
                    <a href="{{ path('app_membre_show', {'id': membre.id}) }}"><button class="btn btn-primary btn-xs"><i class="fa fa-eye"></i></button></a>
                    <a href="{{ path('app_membre_edit', {'id': membre.id}) }}"><button class="btn btn-primary btn-xs"><i class="fa fa-pencil"></i></button></a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5">Aucun membre enregistré en base de données</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
    </div>

    <a href="{{ path('app_membre_new') }}"><button class="btn btn-primary btn-xs"><i class="fa fa-plus"></i> Nouveau membre</button></a>
    </div>
    </section>
</div>
</div>
{% endblock %}
