{% extends 'base.html.twig' %}

{% block body %}
<!-- page start-->
<div class="col-sm-8">
<section class="panel">
<div class="chat-room-head">
<h3><i class="fa fa-angle-right"></i> Gérer les tournois</h3>
</div>
<div class="panel-body">
    <table class="table table-striped table-advance table-hover">
        <thead>
            <tr>
                <th><i class="fa fa-bullhorn"></i>Id</th>
                <th><i class="fa fa-bookmark"></i>Libelle</th>
                <th><i class="fa fa-calendar"></i>Date</th>
                <th><i class="fa fa-users"></i>Participants</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        {% for tournoi in tournois %}
            <tr>
                <td>{{ tournoi.id }}</td>
                <td>{{ tournoi.libelle }}</td>
                <td>{{ tournoi.date ? tournoi.date|date('Y-m-d') : '' }}</td>
                <td>
                    {% if tournoi.participants is not empty %}
                        {{ tournoi.participants|map(p => p.prenom ~ ' ' ~ p.nom)|join(', ') }}
                    {% else %}
                        Aucun participant
                    {% endif %}
                </td>
                <td>
                    <a href="{{ path('app_tournoi_show', {'id': tournoi.id}) }}" class="btn btn-primary btn-xs"><i class="fa fa-eye"></i></a>
                    <a href="{{ path('app_tournoi_edit', {'id': tournoi.id}) }}" class="btn btn-primary btn-xs"><i class="fa fa-pencil"></i></a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5">aucun tournoi enregistré en base de données</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_tournoi_new') }}" class="btn btn-success btn-sm"><i class="fa fa-plus"></i> Ajouter un tournoi</a>
</div><!-- fin div panel-body-->
</section><!-- fin section tournois-->
</div><!--fin div col-sm-8-->
{% endblock %}
