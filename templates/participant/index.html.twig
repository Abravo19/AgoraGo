{% extends 'base.html.twig' %}

{% block body %}
    <div class="col-sm-8">
<section class="panel">
<div class="chat-room-head">
<h3><i class="fa fa-angle-right"></i> Gérer les participants</h3>
</div>
<div class="panel-body">
    <table class="table table-striped table-advance table-hover">
        <thead>
            <tr>
                <th>Id</th>
                <th>Prenom</th>
                <th>Nom</th>
                <th>Telephone</th>
                <th>Email</th>
                <th>Tournois</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for participant in participants %}
            <tr>
                <td>{{ participant.id }}</td>
                <td>{{ participant.prenom }}</td>
                <td>{{ participant.nom }}</td>
                <td>{{ participant.telephone }}</td>
                <td>{{ participant.email }}</td>
                <td>
                    {% if participant.tournois is not empty %}
                        {% for tournoi in participant.tournois %}
                            <span class="badge bg-info text-dark">{{ tournoi.libelle }}</span>
                        {% endfor %}
                    {% else %}
                        <em>Aucun</em>
                    {% endif %}
                </td>
                <td>
                    <a href="{{ path('app_participant_show', {'id': participant.id}) }}" class="btn btn-primary btn-xs"><i class="fa fa-tasks"></i></a>
                    <a href="{{ path('app_participant_edit', {'id': participant.id}) }}" class="btn btn-primary btn-xs"><i class="fa fa-pencil"></i></a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="6">aucun participant enregistré en base de données</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
    <a href="{{ path('app_participant_new') }}" class="btn btn-success btn-sm"><i class="fa fa-plus"></i> Ajouter un participant</a>
</div><!-- fin div panel-body-->
</section><!-- fin section tournois-->
</div><!--fin div col-sm-8-->
{% endblock %}
