{% extends 'base.html.twig' %}

{% block title %}Catégories de Tournois{% endblock %}

{% block body %}
<div class="col-sm-8">
<section class="panel">
<div class="chat-room-head">
<h3><i class="fa fa-angle-right"></i> Gérer les Catégories de Tournois</h3>
</div>
<div class="panel-body">
    <table class="table table-striped table-advance table-hover">
        <thead>
            <tr>
                <th><i class="fa fa-bullhorn"></i> Id</th>
                <th><i class="fa fa-bookmark"></i> Libellé</th>
                <th><i class="fa fa-sitemap"></i> Tournois</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        {% for cat_tournoi in cat_tournois %}
            <tr>
                <td>{{ cat_tournoi.id }}</td>
                <td>{{ cat_tournoi.libelle }}</td>
                <td>
                    {% if cat_tournoi.tournois is not empty %}
                        {{ cat_tournoi.tournois|map(t => t.libelle)|join(', ') }}
                    {% else %}
                        Aucun tournoi
                    {% endif %}
                </td>
                <td>
                    <a href="{{ path('app_cat_tournois_show', {'id': cat_tournoi.id}) }}" class="btn btn-primary btn-xs"><i class="fa fa-eye"></i></a>
                    <a href="{{ path('app_cat_tournois_edit', {'id': cat_tournoi.id}) }}" class="btn btn-primary btn-xs"><i class="fa fa-pencil"></i></a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4">Aucune catégorie trouvée</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_cat_tournois_new') }}" class="btn btn-success btn-sm"><i class="fa fa-plus"></i> Ajouter une catégorie</a>
</div>
</section>
</div>
{% endblock %}
